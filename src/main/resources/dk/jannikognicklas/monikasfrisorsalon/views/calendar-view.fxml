<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="594.0" prefWidth="1077.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.jannikognicklas.monikasfrisorsalon.controllers.BookingController">

    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>

    <top>
        <VBox spacing="8">
            <HBox alignment="TOP_RIGHT" prefHeight="0.0" prefWidth="874.0">
            <Label fx:id="welcomeLabel" prefHeight="39.0" prefWidth="214.0" text="Velkommen, [brugernavn]!">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Region prefHeight="26.0" prefWidth="222.0" />
            <TextField fx:id="searchField" prefHeight="26.0" prefWidth="182.0" promptText="søg" />
            <Region prefHeight="26.0" prefWidth="370.0" />
                <Button mnemonicParsing="false" onAction="#onLogoutButtonPress" prefHeight="26.0" prefWidth="78.0" text="Log ud" />
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="8" BorderPane.alignment="TOP_LEFT">
            <Label text="Vælg dato">
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Label>
            <DatePicker fx:id="datePicker" onAction="#onDateChanged" />
            <Label text="Afmeld booking">
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
            </Label>
            <Button onAction="#onCancelSelected" text="Afmeld" />
        </VBox>
    </left>

    <center>
        <VBox prefHeight="549.0" prefWidth="790.0" spacing="8.0">
            <Label fx:id="bookingDateLabel" text="Aftaler for valgt dato">
                <VBox.margin>
                    <Insets left="5.0" top="10.0" />
                </VBox.margin>
            </Label>
            <TableView fx:id="bookingView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="timeCol" prefWidth="80" text="Tid" />
                    <TableColumn fx:id="nameCol" prefWidth="87.20004272460938" text="Navn" />
               <TableColumn fx:id="phoneCol" prefWidth="69.60003662109375" text="telefon" />
               <TableColumn fx:id="emailCol" prefWidth="75.0" text="Email" />
                    <TableColumn fx:id="employeeCol" minWidth="0.0" prefWidth="73.5999755859375" text="Frisør" />
               <TableColumn fx:id="statusCol" minWidth="0.0" prefWidth="80.80001831054688" text="Status" />
                    <TableColumn fx:id="hairTreatmentCol" prefWidth="108.0" text="Behandling" />
                    <TableColumn fx:id="noteCol" prefWidth="112.79998779296875" text="Noter" />
                </columns>
            <VBox.margin>
               <Insets left="5.0" />
            </VBox.margin>
            </TableView>
        </VBox>
    </center>

   <right>
       <VBox prefHeight="453.0" prefWidth="181.0" spacing="8.0" BorderPane.alignment="CENTER">
           <BorderPane.margin>
               <Insets left="5.0" />
           </BorderPane.margin>
           <Label text="Ny aftale">
             <VBox.margin><Insets top="10.0" /></VBox.margin>
           </Label>
           <TextField fx:id="timeField" promptText="Tid (HH:mm)" />
           <ComboBox fx:id="employeeBox" onAction="#onEmployeeChanged" prefWidth="150.0" promptText="Vælg frisør" />
           <ComboBox fx:id="customerBox" prefWidth="150.0" promptText="Vælg Kunde" />
           <ComboBox fx:id="treatmentBox" prefWidth="150.0" promptText="Vælg Behandling" />
           <TextArea fx:id="noteArea" prefHeight="66.0" prefRowCount="2" prefWidth="862.0" promptText="Note" />
           <HBox prefHeight="0.0" prefWidth="182.0" spacing="8.0">
            <children>
                  <Button onAction="#onAddBooking" text="Tilføj" />
                  <Button mnemonicParsing="false" onAction="#onUpdateBooking" text="Opdater" />
               <Button fx:id="redigerbut" mnemonicParsing="false" onAction="#onEditBooking" text="rediger" />
            </children>
           </HBox>
           <Label text="Kundens information">
              <VBox.margin>
                  <Insets top="20.0" />
              </VBox.margin>
           </Label>
           <TextField fx:id="nameField" promptText="Navn" />
           <TextField fx:id="emailField" promptText="Email" />
           <TextField fx:id="phoneField" promptText="Tlf." />
         <Button mnemonicParsing="false" onAction="#onCreateCustomer" text="Opret Kunde" />
       </VBox>
   </right>
</BorderPane>
